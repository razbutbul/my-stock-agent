generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Favorite {
  id      Int      @id @default(autoincrement())
  symbol  String   @unique @db.VarChar(10)
  addedAt DateTime @default(now()) @map("added_at")

  @@map("favorites")
}
